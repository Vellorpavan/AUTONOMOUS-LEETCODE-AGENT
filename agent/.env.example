# ─── LeetCode Credentials ───────────────────────────────────────────────────
# Get these from your browser cookies at leetcode.com
LEETCODE_SESSION=your_leetcode_session_cookie_here
CSRF_TOKEN=your_csrftoken_cookie_here

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Set ONE or BOTH keys below. The agent auto-detects which to use.
# Override selection with: LLM_PROVIDER=anthropic  or  LLM_PROVIDER=gemini

# Option A — Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# Option B — Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# Explicit override (optional): anthropic | gemini
# LLM_PROVIDER=gemini

# ─── Agent Behaviour ────────────────────────────────────────────────────────
# Max submission attempts per problem before giving up (default: 4)
MAX_ATTEMPTS=4

# Difficulty filter: ALL | Easy | Medium | Hard  (default: ALL)
DIFFICULTY_FILTER=ALL

# Seconds to wait between problems (default: 2)
INTER_PROBLEM_DELAY=2
